# Zerodha Kite Connect credentials
# Get these from https://developers.kite.trade/
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here

# Optional: force a verify=False curl_cffi session for yfinance calls.
# Default behavior: auto-on for Linux (dev container behind corp proxy),
# auto-off for macOS/Windows (let yfinance handle Yahoo's crumb auth).
# Set to "1" to force-on (e.g. on a Mac that's also behind a corp proxy),
# or "0" to force-off (rarely needed).
# YF_USE_PROXY_SESSION=

# Optional: override where the daily access token is cached.
# Default is `<repo>/data/.kite_token.json`, which persists across uvicorn
# restarts on the same machine. Point this at a synced folder
# (e.g. ~/Library/Mobile\ Documents/.../live-stock-app/token.json) if you
# want the same token to be reused across a Mac and a dev container.
# KITE_TOKEN_FILE=/path/to/shared/token.json
